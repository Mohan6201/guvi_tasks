# ============================================================
# AWS Credentials
# The AWS Terraform provider reads these automatically.
# Get these from: AWS Console > IAM > Users > Security Credentials
# ============================================================
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

# ============================================================
# Terraform Variables (TF_VAR_ prefix is required)
# Terraform automatically maps TF_VAR_<name> to var.<name>
# ============================================================

# AWS Region — must be a valid AWS region identifier
TF_VAR_region=us-east-1

# EC2 Instance Type — t2.micro is free-tier eligible
TF_VAR_instance_type=t2.micro

# Key Pair Name — must already exist in the AWS region above
# Create it at: AWS Console > EC2 > Key Pairs
TF_VAR_key_name=my-key-pair
