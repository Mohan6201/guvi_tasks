pipeline {
    agent any

    environment {
        DOCKERHUB_CREDS     = credentials('dockerhub-creds')
        DOCKERHUB_USERNAME  = "${DOCKERHUB_CREDS_USR}"
        DOCKERHUB_PASSWORD  = "${DOCKERHUB_CREDS_PSW}"
        IMAGE_TAG           = "${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Determine Target Repo') {
            steps {
                script {
                    def branch = env.GIT_BRANCH?.replaceAll('origin/', '') ?: 'dev'
                    if (branch == 'master' || branch == 'main') {
                        env.TARGET_REPO = "${DOCKERHUB_USERNAME}/prod"
                    } else {
                        env.TARGET_REPO = "${DOCKERHUB_USERNAME}/dev"
                    }
                    echo "Branch: ${branch} → Target repo: ${env.TARGET_REPO}"
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                    docker build -t ${TARGET_REPO}:${IMAGE_TAG} .
                    docker tag ${TARGET_REPO}:${IMAGE_TAG} ${TARGET_REPO}:latest
                '''
            }
        }

        stage('Push to DockerHub') {
            steps {
                sh '''
                    echo "$DOCKERHUB_PASSWORD" | docker login -u "$DOCKERHUB_USERNAME" --password-stdin
                    docker push ${TARGET_REPO}:${IMAGE_TAG}
                    docker push ${TARGET_REPO}:latest
                '''
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                    chmod +x deploy.sh
                    ./deploy.sh
                '''
            }
        }
    }

    post {
        always {
            sh 'docker logout || true'
        }
        success {
            echo "Build #${env.BUILD_NUMBER} succeeded — deployed ${env.TARGET_REPO}:${env.IMAGE_TAG}"
        }
        failure {
            echo "Build #${env.BUILD_NUMBER} failed — check console output"
        }
    }
}
