# ============================================================
# AWS Credentials
# Get these from: AWS Console > IAM > Users > Security Credentials
# ============================================================
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

# ============================================================
# Terraform Variables (TF_VAR_ prefix is required)
# ============================================================
TF_VAR_aws_region=us-east-1
TF_VAR_environment=production
TF_VAR_cluster_name=trend-eks-cluster
TF_VAR_node_instance_type=t3.medium
TF_VAR_jenkins_instance_type=t2.medium
TF_VAR_key_name=my-key-pair

# ============================================================
# Jenkins Global Environment Variables
# Set these in: Manage Jenkins > System > Global Properties > Environment Variables
# ============================================================
DOCKERHUB_USERNAME=your_dockerhub_username
DOCKERHUB_PASSWORD=your_dockerhub_password_or_token
EKS_CLUSTER_NAME=trend-eks-cluster
AWS_DEFAULT_REGION=us-east-1
