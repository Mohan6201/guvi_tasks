pipeline {
    agent any

    environment {
        DOCKERHUB_CREDENTIALS = credentials('dockerhub-creds')
        IMAGE_NAME             = "${DOCKERHUB_CREDENTIALS_USR}/trend-app"
        IMAGE_TAG              = "${env.BUILD_NUMBER}"
        EKS_CLUSTER            = "${env.EKS_CLUSTER_NAME}"
        AWS_REGION             = "${env.AWS_DEFAULT_REGION}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                    docker build -t ${IMAGE_NAME}:${IMAGE_TAG} .
                    docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:latest
                '''
            }
        }

        stage('Test Docker Image') {
            steps {
                sh '''
                    docker run -d --name trend-test -p 8081:80 ${IMAGE_NAME}:${IMAGE_TAG}
                    sleep 10
                    curl -f http://localhost:8081 || (docker logs trend-test && exit 1)
                    docker stop trend-test
                    docker rm trend-test
                '''
            }
        }

        stage('Push to DockerHub') {
            steps {
                sh '''
                    echo "$DOCKERHUB_CREDENTIALS_PSW" | docker login -u "$DOCKERHUB_CREDENTIALS_USR" --password-stdin
                    docker push ${IMAGE_NAME}:${IMAGE_TAG}
                    docker push ${IMAGE_NAME}:latest
                '''
            }
        }

        stage('Deploy to EKS') {
            steps {
                sh '''
                    aws eks update-kubeconfig --region ${AWS_REGION} --name ${EKS_CLUSTER}
                    kubectl apply -f k8s/
                    kubectl set image deployment/trend-app trend-app=${IMAGE_NAME}:${IMAGE_TAG}
                    kubectl rollout status deployment/trend-app --timeout=120s
                '''
            }
        }
    }

    post {
        always {
            sh 'docker logout || true'
        }
        success {
            echo "Build #${env.BUILD_NUMBER} succeeded — deployed ${env.IMAGE_NAME}:${env.IMAGE_TAG} to EKS"
        }
        failure {
            echo "Build #${env.BUILD_NUMBER} failed — check console output"
        }
    }
}
