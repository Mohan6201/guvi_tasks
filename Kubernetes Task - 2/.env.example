# ============================================================
# AWS Credentials
# Get these from: AWS Console > IAM > Users > Security Credentials
# ============================================================
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_DEFAULT_REGION=us-east-1

# ============================================================
# EKS Cluster Configuration
# ============================================================

# Name of the EKS cluster to create
CLUSTER_NAME=nginx-eks-cluster

# Kubernetes version
K8S_VERSION=1.29

# EC2 instance type for worker nodes (t3.medium recommended for EKS)
NODE_INSTANCE_TYPE=t3.medium

# Node group scaling config
NODE_DESIRED=2
NODE_MIN=1
NODE_MAX=3
