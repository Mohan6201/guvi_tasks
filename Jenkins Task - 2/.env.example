# ============================================================
# AWS Credentials
# Get these from: AWS Console > IAM > Users > Security Credentials
# ============================================================
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

# ============================================================
# Terraform Variables (TF_VAR_ prefix is required)
# ============================================================
TF_VAR_region=us-east-1
TF_VAR_instance_type=t2.medium
TF_VAR_key_name=my-key-pair

# ============================================================
# Jenkins Email Configuration
# Set these as Jenkins Global Environment Variables (not loaded here)
# Manage Jenkins > System > Global Properties > Environment Variables
# ============================================================
EMAIL_RECIPIENT=your-email@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-gmail@gmail.com
# Use a Gmail App Password (not your main password)
# Generate at: Google Account > Security > 2-Step Verification > App Passwords
SMTP_PASSWORD=your_gmail_app_password
